# Local development only — bypasses the Vercel proxy and calls Anthropic directly from your browser.
# WARNING: any value set here ends up in the browser bundle and network requests.
# Never use a production key here; use a separate dev/test key.
# Leave blank (or omit this file) to get demo-data fallback mode instead.
VITE_CLAUDE_API_KEY=your_dev_key_here

# Production (Vercel deployment only — set this in the Vercel dashboard, not here):
# CLAUDE_API_KEY=your_production_key_here
